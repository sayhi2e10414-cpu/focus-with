# Core server
FOCUS_HOST=127.0.0.1
FOCUS_PORT=8765
FOCUS_TIMEZONE=Asia/Shanghai
FOCUS_DATA_DIR=./data

# Generated by scripts/install.sh. Never commit real values.
FOCUS_API_TOKEN=
FOCUS_PHONE_TOKEN=

# Optional AI companion: none, anthropic, openai-responses, or openai-compatible
FOCUS_AI_PROVIDER=none
FOCUS_AI_API_KEY=
FOCUS_AI_MODEL=
FOCUS_AI_BASE_URL=

# Optional Telegram delivery
FOCUS_TELEGRAM_BOT_TOKEN=
FOCUS_TELEGRAM_CHAT_ID=

# Optional Remote MCP for OAuth-capable clients. Use scripts/setup_remote_env.py instead of
# filling these by hand. Remote mode requires HTTPS and both values below.
FOCUS_PUBLIC_URL=
FOCUS_OAUTH_PASSWORD_HASH=
FOCUS_OAUTH_ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback,https://claude.com/api/mcp/auth_callback
